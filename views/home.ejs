<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mailx — AI Email Assistant</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <main id="app-dashboard" >
        <aside class="sidebar">
            <div class="sidebar-top">
                <div class="sidebar-brand">Mailx</div>
                <nav>
                    <ul class="nav-menu">
                        <li class="nav-item active" data-tab="inbox">
                            <button>
                                <div class="nav-link-group">
                                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
                                        viewBox="0 0 24 24">
                                        <path
                                            d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0a2 2 0 01-2 2H6a2 2 0 01-2-2m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4">
                                        </path>
                                    </svg>
                                    <span>Inbox</span>
                                </div>
                                <span class="badge-count" id="inbox-badge">0</span>
                            </button>
                        </li>
                        <li class="nav-item" data-tab="unread">
                            <button>
                                <div class="nav-link-group">
                                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
                                        viewBox="0 0 24 24">
                                        <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path
                                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z">
                                        </path>
                                    </svg>
                                    <span>Unread</span>
                                </div>
                            </button>
                        </li>
                        <li class="nav-item" data-tab="sent">
                            <button>
                                <div class="nav-link-group">
                                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
                                        viewBox="0 0 24 24">
                                        <path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                                    </svg>
                                    <span>Sent</span>
                                </div>
                            </button>
                        </li>
                        <li class="nav-item nav-item-ai" data-tab="ai-drafts">
                            <button>
                                <div class="nav-link-group">
                                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
                                        viewBox="0 0 24 24">
                                        <path
                                            d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z">
                                        </path>
                                    </svg>
                                    <span>AI Drafts</span>
                                </div>
                            </button>
                        </li>
                        <li class="nav-item" data-tab="settings">
                            <button>
                                <div class="nav-link-group">
                                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
                                        viewBox="0 0 24 24">
                                        <path
                                            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z">
                                        </path>
                                        <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    </svg>
                                    <span>Settings</span>
                                </div>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>

            <div class="sidebar-bottom logout-btn">
                <ul class="nav-menu">
                    <li class="nav-item" id="logout-trigger-btn">
                        <button>
                            <div class="nav-link-group">
                                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
                                    viewBox="0 0 24 24">
                                    <path
                                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 01-3-3h4a3 3 0 013 3v1">
                                    </path>
                                </svg>
                                <span>Logout</span>
                            </div>
                        </button>
                    </li>
                </ul>
            </div>
        </aside>

        <section class="inbox-panel">
            <div class="panel-header">
                <div class="panel-title-area">
                    <h2 id="inbox-title">Inbox</h2>
                </div>
                <div class="search-wrapper">
                    <svg class="search-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"
                        viewBox="0 0 24 24">
                        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                    <input type="text" id="search-bar" class="search-input" placeholder="Search emails...">
                </div>
            </div>
            <div class="email-list" id="email-feed"></div>
        </section>

        <section class="preview-panel">
            <div class="preview-header">
                <div>
                    <h3 class="preview-subject" id="view-subject">Select an email to read</h3>
                    <div class="profile-row">
                        <div class="avatar" id="view-avatar">-</div>
                        <div class="profile-details">
                            <h4 id="view-sender">No Selected Sender</h4>
                            <p id="view-meta"></p>
                        </div>
                    </div>
                </div>
                <div class="action-icon-group">
                    <button class="btn-icon"><svg width="16" height="16" fill="none" stroke="currentColor"
                            stroke-width="2" viewBox="0 0 24 24">
                            <path d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
                        </svg></button>
                    <button class="btn-icon"><svg width="16" height="16" fill="none" stroke="currentColor"
                            stroke-width="2" viewBox="0 0 24 24">
                            <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path>
                        </svg></button>
                    <button class="btn-icon"><svg width="16" height="16" fill="none" stroke="currentColor"
                            stroke-width="2" viewBox="0 0 24 24">
                            <path
                                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16">
                            </path>
                        </svg></button>
                </div>
            </div>

            <div class="preview-body" id="view-body">
                Please select an email thread from the panel list to view detailed contents.
            </div>

            <div class="ai-assistant-drawer" id="ai-drawer">
                <div class="ai-status-bar">
                    <div class="ai-indicator-group">
                        <div class="ai-glowing-dot"></div>
                        <span class="ai-status-text">Mailx AI Context Assistant</span>
                    </div>
                    <div class="ai-intent-chips">
                        <button class="intent-pill active" data-intent="agree">Agree</button>
                        <button class="intent-pill" data-intent="decline">Decline</button>
                        <button class="intent-pill" data-intent="later">Hold Off</button>
                    </div>
                </div>
                <div class="draft-space">
                    <textarea class="draft-textarea" id="ai-draft-output"
                        placeholder="AI Smart Response loading..."></textarea>
                    <div class="draft-actions">
                        <button class="btn-secondary" id="btn-regenerate">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"
                                viewBox="0 0 24 24">
                                <path
                                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 15.19M9 15.511L15.111 9.4m0 0H10.5m4.611 0v4.611">
                                </path>
                            </svg> Regenerate
                        </button>
                        <button class="btn-primary" id="btn-send-reply">
                            <span>Send Reply</span>
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"
                                viewBox="0 0 24 24">
                                <path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <script src="app.js"></script>
</body>

</html>