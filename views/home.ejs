<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Mailx — Inbox</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css"/>
  <link rel="stylesheet" href="homestyle.css"/>

</head>
<body>

  <!-- ── Top Bar ── -->
  <header class="topbar">
    <a class="wordmark" href="/">Mailx</a>

    <div class="top-search-wrap">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input class="top-search-input" id="search-bar" type="text" placeholder="Search emails..."/>
    </div>

    <div class="topbar-right">
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
        <span class="theme-icon" id="theme-icon">○</span>
        <span id="theme-label">Dark</span>
      </button>
      <button onclick="window.location.href='/auth/logout'">
        <div class="nav-link-group">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Logout
        </div>
      </button>
    </div>
  </header>

  <div class="app-workspace">

    <!-- ── Sidebar ── -->
    <div class="sidebar" id="sidebar">
      
        
        <button class="hamburger-toggle" id="hamburger-btn" aria-label="Toggle Navigation">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        <ul class="nav-list">
          <li class="nav-item active" data-tab="inbox">
            <button>
              <div class="nav-link-group">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <span>Inbox</span>
              </div>
              <span class="badge-count" id="inbox-badge">0</span>
            </button>
          </li>

          <li class="nav-item" data-tab="sent">
            <button>
              <div class="nav-link-group">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                <span>Sent</span>
              </div>
            </button>
          </li>

          <li class="nav-item" data-tab="archive">
            <button>
              <div class="nav-link-group">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0a2 2 0 01-2 2H6a2 2 0 01-2-2m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                </svg>
                <span>Archive</span>
              </div>
            </button>
          </li>
        </ul>
      

      
    </div>

  
    <main class="content-area state-inbox" id="app-content-area">

      <!-- s1: Inbox List -->
      <section class="list-panel">

        <div class="list-header">
          <h2 class="list-title" id="inbox-title">Inbox</h2>
        </div>

        <div class="email-feed" id="email-feed">
          <div class="feed-state">Loading emails...</div>
        </div>

      </section>

      <!-- s2: Email Preview + AI Panel -->
      <section class="preview-panel">

        <!-- left email -->
        <div class="main-mail-view">


          <div class="preview-header">
            <div class="subject-container-row">
              <button class="back-arrow-btn" id="go-back-to-inbox" title="Back to Inbox">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
              </button>
              <h3 class="preview-subject" id="view-subject">Select an email to read</h3>
            </div>

            <div class="sender-row">
              <div class="sender-info">
                <div class="avatar" id="view-avatar">—</div>
                <div>
                  <div class="sender-name" id="view-sender">No sender selected</div>
                  <div class="sender-meta" id="view-meta"></div>
                </div>
              </div>
              <!-- <div class="action-group">
                <button class="icon-btn" id="reply-btn" title="Reply">
                  <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                  </svg>
                </button>
                <button class="icon-btn" title="Save">
                  <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
                  </svg>
                </button>
                <button class="icon-btn" title="Delete">
                  <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                </button>
              </div> -->
            </div>
          </div>

          <!-- Email body + reply drawer -->
          <div class="preview-body" id="view-body-scroll-context">

            <div id="view-body">
              Select an email from the list to read its contents.
            </div>

            <!-- Reply drawer-->
            <div class="inline-reply-container hidden" id="ai-drawer">

              <div class="reply-toolbar">
                <div class="ai-indicator">
                  <div class="ai-dot"></div>
                  <span class="ai-label">AI Generated Reply</span>
                </div>
                <div class="tone-group">
                  <span class="tone-label">Tone</span>
                  <select class="tone-select" id="tone-select">
                    <option value="Professional">Professional</option>
                    <option value="Casual">Casual</option>
                    <option value="Friendly">Friendly</option>
                  </select>
                </div>
                <button class="btn-secondary" id="close-reply">Close</button>
              </div>

              <textarea class="draft-textarea" id="ai-draft-output" placeholder="AI draft loading..."></textarea>

              <div class="draft-actions">
                <button class="btn-secondary" id="btn-regenerate">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                  </svg>
                  Regenerate
                </button>
                <button class="btn-primary" id="btn-send-reply">
                  Send Reply
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                  </svg>
                </button>
              </div>

            </div>
            
          </div>
        </div>

        <!-- Right: AI Summary Panel — always visible in email view -->
        <aside class="summary-panel">
          <div class="summary-card">
            <div class="ai-indicator">
              <div class="ai-dot"></div>
              <span class="ai-label">Mailx AI</span>
            </div>
            <h4>Summary</h4>
            <div id="ai-summary">Open an email to generate a summary.</div>
          </div>

          <div class="summary-actions">
            <button class="action-card" id="reply-action">
              <strong>↩ Reply</strong>
              <span>Respond to this email</span>
            </button>
            <button class="action-card">
              <strong>🗄 Archive</strong>
              <span>Save for later</span>
            </button>
            <button class="action-card delete">
              <strong>🗑 Delete</strong>
              <span>Remove this email</span>
            </button>
          </div>
        </aside>

      </section>

    </main>
  </div>

  <script src="app.js"></script>
  <script>
    // ── Dark mode ──
    const html = document.documentElement;
    const themeIcon = document.getElementById('theme-icon');
    const themeLabel = document.getElementById('theme-label');

    const saved = localStorage.getItem('mailx-theme');
    if (saved) { html.setAttribute('data-theme', saved); updateThemeUI(saved); }

    function toggleTheme() {
      const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('mailx-theme', next);
      updateThemeUI(next);
    }

    function updateThemeUI(t) {
      themeIcon.textContent = t === 'dark' ? '●' : '○';
      themeLabel.textContent = t === 'dark' ? 'Light' : 'Dark';
    }
  </script>

</body>
</html>
