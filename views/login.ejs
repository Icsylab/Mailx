<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Mailx — AI Email Assistant</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/loginstyle.css" />

</head>
<body>

<div class="page">

  <!-- Topbar -->
  <nav class="topbar">
    <a class="wordmark" href="/">Mailx</a>
    <div class="topbar-right">
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
        <span class="theme-icon" id="theme-icon">○</span>
        <span id="theme-label">Dark</span>
      </button>
      <!-- <span class="badge">Beta</span> -->
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="hero">
      <p class="hero-eyebrow">AI Email Assistant</p>

      <h1 class="hero-title">
        Inbox,<br><em>handled.</em>
      </h1>

      <div class="rule"></div>

      <p class="hero-sub">
        Reads your Gmail. Understands context.<br>
        Drafts replies that sound like you.
      </p>

      <!-- ── Auth card ── -->
      <div class="auth-card">
        <p class="auth-card-label">Sign in to continue</p>

        <!-- Google -->
        <a class="auth-btn" href="/auth/google">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google
        </a>

        <!-- Divider -->
        <div class="auth-divider"><span>or</span></div>

        <!-- for devs -->
        <a class="auth-btn dev-btn" href="/auth/github">
          <!-- <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg> -->
          Continue anonymously
          <span style="margin-left:auto; font-size:0.65rem; opacity:0.5; font-weight:400;">for devs</span>
        </a>

        <!-- <p class="auth-note">
          🔒<strong>OAuth 2.0 secured</strong>  We never store your emails.
        </p> -->
      </div>

      <!-- Feature pills -->
      <div class="features">
        <div class="feature"><span class="feature-dot"></span>Smart AI reply drafts</div>
        <div class="feature"><span class="feature-dot"></span>Protect from scams</div>
        <div class="feature"><span class="feature-dot"></span>Zero emails stored</div>
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- How it works -->
    <section class="how">
      <p class="how-label">How it works</p>

      <div class="steps">

        <div class="step-card" data-num="1">
          <div class="step-card-icon">🔗</div>
          <p class="step-card-num">Step 01</p>
          <h3 class="step-card-title">Connect</h3>
          <p class="step-card-desc">Sign in with Google. Mailx securely connects to your Gmail in seconds — no passwords stored, ever.</p>
        </div>

        <div class="step-card" data-num="2">
          <div class="step-card-icon">✦</div>
          <p class="step-card-num">Step 02</p>
          <h3 class="step-card-title">Summarise</h3>
          <p class="step-card-desc">AI reads each email and distils it to what matters — no more wading through walls of text.</p>
        </div>

        <div class="step-card" data-num="3">
          <div class="step-card-icon">↗</div>
          <p class="step-card-num">Step 03</p>
          <h3 class="step-card-title">Reply</h3>
          <p class="step-card-desc">Get a perfectly crafted draft instantly. Adjust the tone, edit if needed, and send in one click.</p>
        </div>

      </div>
    </section>

    <!-- 
    <div class="trust">
      <div class="trust-item"><span class="trust-icon">🔒</span>OAuth 2.0 secured</div>
      <div class="trust-item"><span class="trust-icon">⚡</span>Powered by Gemini AI</div>
      <div class="trust-item"><span class="trust-icon">📭</span>Emails never stored</div>
      <div class="trust-item"><span class="trust-icon">🌐</span>Works with any Gmail</div>
    </div> -->

  </main>

  <footer class="footer">
    Built with Gmail API &amp; Gemini AI &nbsp;·&nbsp;
    <a href="#">Privacy</a> &nbsp;·&nbsp;
    © 2026 Mailx
  </footer>

</div>

<!-- <span class="corner-mark bl">v1.0 Beta</span>
<span class="corner-mark br">Est. 2026</span> -->

<script src="/loginapp.js"></script>

</body>
</html>
